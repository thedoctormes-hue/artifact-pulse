[Unit]
Description=LabDoctorM Artifact Health Check — мониторинг здоровья артефактов
After=network.target

[Service]
Type=oneshot
ExecStartPre=/bin/mkdir -p /root/LabDoctorM/.qwen/artifacts
ExecStart=/bin/bash -c 'cd /root/LabDoctorM/projects/artifact-pulse && python3 artifact_health.py --json > /root/LabDoctorM/.qwen/artifacts/health_latest.json 2>&1'
User=root
WorkingDirectory=/root/LabDoctorM
StandardOutput=journal
StandardError=journal
TimeoutSec=120

[Install]
WantedBy=multi-user.target
